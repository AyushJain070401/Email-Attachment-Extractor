{
  "name": "email-attachment-extractor",
  "version": "1.0.1",
  "description": "Extracts only real email attachments from raw RFC822 emails, intelligently filtering out signature images, inline images, logos, and tracking pixels.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run check:dist",
    "build:watch": "npm run check:dist",
    "check:dist": "node -e \"const fs=require('fs'); const required=['dist/index.js','dist/index.d.ts']; const missing=required.filter((p)=>!fs.existsSync(p)); if(missing.length){console.error('Missing build artifacts:', missing.join(', ')); process.exit(1);} console.log('dist artifacts look good.');\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run check:dist"
  },
  "keywords": [
    "email",
    "attachment",
    "extractor",
    "mailparser",
    "mime",
    "rfc822",
    "filter",
    "inline",
    "signature",
    "nodejs",
    "typescript"
  ],
  "author": "Ayush Jain <ayushjain070401@gmail.com> (https://github.com/ayushjain070401)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AyushJain070401/Email-Attachment-Extractor.git"
  },
  "bugs": {
    "url": "https://github.com/AyushJain070401/Email-Attachment-Extractor/issues"
  },
  "homepage": "https://github.com/AyushJain070401/Email-Attachment-Extractor#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mailparser": "^3.7.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
